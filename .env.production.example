# =============================================================================
# Astro Platform — Production environment template
# Copy to .env.production (never commit real secrets): cp .env.production.example .env.production
#
# Production rules:
# - ALLOW_DEV_TELEGRAM_AUTH must be false
# - SAAS_COOKIE_SECURE must be true
# - SAAS_SESSION_SECRET must be a strong unique value (not the dev default)
# - CORS_ORIGINS must list explicit frontend origins only
# - TELEGRAM_BOT_TOKEN is required for Mini App auth
# - Superadmin must remain access-restricted (platform role only)
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_MODE=remote
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=
NEXT_PUBLIC_DEFAULT_DASHBOARD_TENANT_ID=
NEXT_PUBLIC_DEFAULT_LOCALE=en

NEXT_PUBLIC_MINIAPP_URL=https://app.example.com
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.example.com
NEXT_PUBLIC_SUPERADMIN_URL=https://admin-internal.example.com

# -----------------------------------------------------------------------------
# SaaS API
# -----------------------------------------------------------------------------
APP_ENV=production
SERVICE_NAME=saas-api
APP_VERSION=0.1.0
SAAS_API_PORT=8000

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/astro_saas
SAAS_SESSION_SECRET=replace-with-strong-random-secret-min-32-chars
SAAS_COOKIE_NAME=saas_session
SAAS_COOKIE_SECURE=true
SAAS_COOKIE_SAMESITE=lax
SAAS_COOKIE_DOMAIN=.example.com
CORS_ORIGINS=https://app.example.com,https://dashboard.example.com,https://admin-internal.example.com

TELEGRAM_BOT_TOKEN=
ALLOW_DEV_TELEGRAM_AUTH=false
ASTRO_API_BASE_URL=http://astro-api:8100
ASTRO_API_MODE=remote
ASTRO_API_TOKEN=
ASTRO_API_TIMEOUT_SECONDS=20
PAYMENT_API_MODE=remote
PAYMENT_API_BASE_URL=https://payment-api.example.com
PAYMENT_API_TOKEN=
PAYMENT_API_TIMEOUT_MS=30000
MINIAPP_PUBLIC_BASE_URL=https://app.example.com
ALLOW_STAGING_MOCKS=false
END_USER_COOKIE_NAME=saas_end_user_session

MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_ROOT=var/media
MEDIA_PUBLIC_BASE_URL=https://api.example.com/media
MEDIA_MAX_UPLOAD_MB=5

# -----------------------------------------------------------------------------
# Astro API — internal network only; do not expose publicly to browsers
# -----------------------------------------------------------------------------
ASTRO_API_PORT=8100

# -----------------------------------------------------------------------------
# Bootstrap (one-time pilot setup; rotate credentials after bootstrap)
# -----------------------------------------------------------------------------
SAAS_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SAAS_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
SAAS_BOOTSTRAP_BLOGGER_EMAIL=
SAAS_BOOTSTRAP_BLOGGER_PASSWORD=
