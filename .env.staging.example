# =============================================================================
# Astro Platform — Staging environment template
# Copy to .env.staging (never commit real secrets): cp .env.staging.example .env.staging
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_MODE=remote
NEXT_PUBLIC_API_BASE_URL=https://saas-api.staging.example.com
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=mystic-dark
NEXT_PUBLIC_DEFAULT_DASHBOARD_TENANT_ID=tenant_mystic
NEXT_PUBLIC_DEFAULT_LOCALE=en

NEXT_PUBLIC_MINIAPP_URL=https://miniapp.staging.example.com
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.staging.example.com
NEXT_PUBLIC_SUPERADMIN_URL=https://superadmin.staging.example.com

# -----------------------------------------------------------------------------
# SaaS API
# -----------------------------------------------------------------------------
APP_ENV=staging
SERVICE_NAME=saas-api
APP_VERSION=0.1.0
SAAS_API_PORT=8000

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/astro_saas_staging
SAAS_SESSION_SECRET=replace-with-strong-random-secret-min-32-chars
SAAS_COOKIE_NAME=saas_session
SAAS_COOKIE_SECURE=true
SAAS_COOKIE_SAMESITE=lax
SAAS_COOKIE_DOMAIN=
CORS_ORIGINS=https://miniapp.staging.example.com,https://dashboard.staging.example.com,https://superadmin.staging.example.com

TELEGRAM_BOT_TOKEN=
ALLOW_DEV_TELEGRAM_AUTH=false
ASTRO_API_BASE_URL=http://astro-api:8100
ASTRO_API_MODE=remote
ASTRO_API_TOKEN=
ASTRO_API_TIMEOUT_SECONDS=20
PAYMENT_API_MODE=remote
PAYMENT_API_BASE_URL=https://payment-api.staging.example.com
PAYMENT_API_TOKEN=
PAYMENT_API_TIMEOUT_MS=30000
MINIAPP_PUBLIC_BASE_URL=https://miniapp.staging.example.com
ALLOW_STAGING_MOCKS=false
END_USER_COOKIE_NAME=saas_end_user_session

MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_ROOT=var/media
MEDIA_PUBLIC_BASE_URL=https://saas-api.staging.example.com/media
MEDIA_MAX_UPLOAD_MB=5

# -----------------------------------------------------------------------------
# Astro API
# -----------------------------------------------------------------------------
ASTRO_API_PORT=8100

# -----------------------------------------------------------------------------
# Bootstrap (rotate before pilot; use strong passwords)
# -----------------------------------------------------------------------------
SAAS_BOOTSTRAP_ADMIN_EMAIL=admin@staging.example.com
SAAS_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
SAAS_BOOTSTRAP_BLOGGER_EMAIL=blogger@staging.example.com
SAAS_BOOTSTRAP_BLOGGER_PASSWORD=change-me-strong-password
