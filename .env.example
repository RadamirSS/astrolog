# =============================================================================
# Astro Platform — Local development environment template
# Copy to .env.local: cp .env.example .env.local
# Mock mode remains the default for frontend-only development.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Next.js apps: miniapp, dashboard, superadmin)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_MODE=mock
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=mystic-dark
NEXT_PUBLIC_DEFAULT_DASHBOARD_TENANT_ID=tenant_mystic
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Cross-app preview URLs (local dev)
NEXT_PUBLIC_MINIAPP_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_SUPERADMIN_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# SaaS API
# -----------------------------------------------------------------------------
APP_ENV=development
SERVICE_NAME=saas-api
APP_VERSION=0.1.0
SAAS_API_PORT=8000

DATABASE_URL=postgresql+psycopg://astro:astro@localhost:5432/astro_saas
SAAS_SESSION_SECRET=dev-session-secret-change-in-production
SAAS_COOKIE_NAME=saas_session
SAAS_COOKIE_SECURE=false
SAAS_COOKIE_SAMESITE=lax
SAAS_COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Telegram runtime (BE-03) — dev fallback allowed locally only
TELEGRAM_BOT_TOKEN=
ALLOW_DEV_TELEGRAM_AUTH=true
ASTRO_API_BASE_URL=http://localhost:8100
ASTRO_API_TIMEOUT_SECONDS=20
END_USER_COOKIE_NAME=saas_end_user_session

# Media storage (BE-04)
MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_ROOT=var/media
MEDIA_PUBLIC_BASE_URL=http://localhost:8000/media
MEDIA_MAX_UPLOAD_MB=5

# -----------------------------------------------------------------------------
# Astro API (internal — not exposed to frontend)
# -----------------------------------------------------------------------------
# Override SERVICE_NAME when running astro-api: SERVICE_NAME=astro-api
ASTRO_API_PORT=8100
ASTRO_API_MODE=mock
ASTRO_API_TOKEN=
ASTRO_API_TIMEOUT_MS=30000
# CORS_ORIGINS shared with SaaS API above

# -----------------------------------------------------------------------------
# Payment API (external — server-side only)
# -----------------------------------------------------------------------------
PAYMENT_API_MODE=mock
PAYMENT_API_BASE_URL=
PAYMENT_API_TOKEN=
PAYMENT_API_TIMEOUT_MS=30000
MINIAPP_PUBLIC_BASE_URL=http://localhost:3000
ALLOW_STAGING_MOCKS=false

# -----------------------------------------------------------------------------
# Miniapp payment return URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
PAYMENT_SUCCESS_PATH=/payment/success
PAYMENT_CANCEL_PATH=/payment/cancel
PAYMENT_PENDING_PATH=/payment/pending

# -----------------------------------------------------------------------------
# Bootstrap accounts (pilot seed — change before any shared/staging deploy)
# -----------------------------------------------------------------------------
SAAS_BOOTSTRAP_ADMIN_EMAIL=admin@astro.local
SAAS_BOOTSTRAP_ADMIN_PASSWORD=admin123!
SAAS_BOOTSTRAP_BLOGGER_EMAIL=blogger@astro.local
SAAS_BOOTSTRAP_BLOGGER_PASSWORD=blogger123!
